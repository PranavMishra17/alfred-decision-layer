# ============================================================
# alfred_ Decision Layer — Environment Variables
# ============================================================
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# For Vercel deployment, set these in the Vercel dashboard:
#   https://vercel.com/docs/environment-variables
#
# NOTE: This project uses BYOK (Bring Your Own Key) by default.
# API keys entered in the browser Settings panel are stored in
# localStorage and sent per-request via headers. The env vars
# below serve as OPTIONAL server-side fallbacks when no BYOK
# key is present.
# ============================================================


# ----------------------------------------------------------
# ANTHROPIC (Required — either here or via BYOK in browser)
# ----------------------------------------------------------
# Get your API key: https://console.anthropic.com/settings/keys
# Docs:             https://docs.anthropic.com/en/api/getting-started
# Pricing:          https://www.anthropic.com/pricing
#
# Primary model:    claude-sonnet-4-6       (P2 Reason phase)
# Fallback model:   claude-haiku-4-5        (safe-mode on failure)
#
# The key is used server-side in /api/decide — never exposed to the client.
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxx


# ----------------------------------------------------------
# CARTESIA (Optional — TTS output)
# ----------------------------------------------------------
# Get your API key: https://play.cartesia.ai/keys
# Docs:             https://docs.cartesia.ai
#
# If absent, TTS is disabled. alfred_ responses are text-only.
# The key is used server-side in /api/tts — never exposed to the client.
CARTESIA_API_KEY=sk-cart-xxxxxxxxxxxxxxxxxxxx


# ----------------------------------------------------------
# APP CONFIG (Optional — override defaults)
# ----------------------------------------------------------
# Decision threshold: 0.1 to 0.9 (default: 0.5)
# Lower = more silent execution, higher = more confirmations.
# Can also be adjusted at runtime via the Settings panel slider.
# DECISION_THRESHOLD=0.5

# LLM timeout in milliseconds before triggering Haiku safe-mode.
# Default: 12000 (12 seconds)
# LLM_TIMEOUT_MS=12000

# Undo window for NOTIFY verdicts in milliseconds.
# Default: 10000 (10 seconds)
# UNDO_WINDOW_MS=10000


# ----------------------------------------------------------
# DEVELOPMENT (Optional)
# ----------------------------------------------------------
# Enable verbose trace logging to server console.
# TRACE_LOG=true

# Force all LLM calls to use Haiku (cheaper, faster, for dev iteration).
# FORCE_HAIKU=false
